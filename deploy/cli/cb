#!/usr/bin/env bash
# cb - Circuit Breaker management CLI

[[ -f /etc/circuitbreaker/.env ]] && source /etc/circuitbreaker/.env

SERVICES=(
  "circuitbreaker-postgres"
  "circuitbreaker-pgbouncer"
  "circuitbreaker-redis"
  "circuitbreaker-nats"
  "circuitbreaker-backend"
  "circuitbreaker-worker@discovery"
  "circuitbreaker-worker@notification"
  "circuitbreaker-worker@telemetry"
  "circuitbreaker-worker@monitor_scheduler"
  "circuitbreaker-worker@monitor_poll"
  "nginx"
)
[[ "${DOCKER_PROXY_ENABLED:-false}" == "true" ]] && \
  SERVICES+=("circuitbreaker-docker-proxy")

cmd_status() {
  echo ""
  printf "  %-36s %-12s %s\n" "SERVICE" "STATUS" "UPTIME"
  printf "  %-36s %-12s %s\n" "────────────────────────────────────" "──────────" "──────"
  for svc in "${SERVICES[@]}"; do
    active=$(systemctl is-active "$svc" 2>/dev/null)
    uptime=$(systemctl show "$svc" --property=ActiveEnterTimestamp \
      --value 2>/dev/null | xargs -I{} date -d{} "+%H:%M %b %d" 2>/dev/null || echo "—")
    color="\033[0;32m"; [[ "$active" != "active" ]] && color="\033[0;31m"
    printf "  %-36s ${color}%-12s\033[0m %s\n" "$svc" "$active" "$uptime"
  done
  echo ""
}

cmd_doctor() {
  if [[ $EUID -ne 0 ]]; then
    exec sudo /usr/local/bin/cb doctor
  fi
  echo ""
  echo "  Circuit Breaker Health Check"
  echo "  ─────────────────────────────────────────"
  FAILED=0
  check() {
    local name=$1 cmd=$2 hint=$3
    if eval "$cmd" &>/dev/null; then
      printf "  \033[0;32m✓\033[0m  %-20s OK\n" "$name"
    else
      printf "  \033[0;31m✗\033[0m  %-20s FAILED\n" "$name"
      echo "     → $hint"
      FAILED=$((FAILED + 1))
    fi
  }
  check "PostgreSQL (5432)"  "nc -z 127.0.0.1 5432"           "journalctl -u circuitbreaker-postgres -n 30"
  check "pgbouncer (6432)"   "nc -z 127.0.0.1 6432"           "journalctl -u circuitbreaker-pgbouncer -n 30"
  check "DB connection"      "PGPASSWORD=\"$CB_DB_PASSWORD\" psql -h 127.0.0.1 -p 6432 -U breaker -d circuitbreaker -c '\q'" "Check pgbouncer userlist.txt hash"
  check "Redis (6379)"       "redis-cli -a \"$CB_REDIS_PASSWORD\" --no-auth-warning PING | grep -q PONG" "journalctl -u circuitbreaker-redis -n 30"
  # A PING only proves the socket answers — it doesn't touch the data directory
  # at all, so a UID mismatch there (e.g. after the redis system user gets
  # self-healed with a new UID) stays invisible here while BGSAVE quietly
  # fails with EACCES on every save interval.
  if [[ -d "${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis" ]]; then
    redis_svc_user=$(systemctl show circuitbreaker-redis -p User --value 2>/dev/null)
    check "Redis data dir ownership" \
      "[[ \"\$(stat -c %u \"${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis\")\" == \"\$(id -u \"${redis_svc_user:-redis}\" 2>/dev/null)\" ]]" \
      "chown -R ${redis_svc_user:-redis}:${redis_svc_user:-redis} ${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis && systemctl restart circuitbreaker-redis"
    # DAC ownership can be perfectly correct while SELinux still blocks writes:
    # redis-server runs confined as redis_t, which only gets full read/write on
    # paths labeled redis_var_lib_t. CB_DATA_DIR is a non-standard path, so it
    # inherits generic var_lib_t (read-only-ish for confined domains) unless
    # explicitly relabeled — this is what actually broke BGSAVE in practice,
    # not a UID mismatch.
    if command -v getenforce &>/dev/null && [[ "$(getenforce)" != "Disabled" ]]; then
      check "SELinux context on Redis data dir" \
        "[[ \"\$(stat -c %C \"${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis\" 2>/dev/null)\" == *redis_var_lib_t* ]]" \
        "semanage fcontext -a -t redis_var_lib_t '${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis(/.*)?' || semanage fcontext -m -t redis_var_lib_t '${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis(/.*)?'; restorecon -R ${CB_DATA_DIR:-/var/lib/circuitbreaker}/redis && systemctl restart circuitbreaker-redis"
    fi
  fi
  check "NATS (4222)"        "nc -z 127.0.0.1 4222"           "journalctl -u circuitbreaker-nats -n 30"
  check "Backend API (8000)" "curl -sf http://127.0.0.1:8000/api/v1/health" "journalctl -u circuitbreaker-backend -n 30"
  if [[ "${DOCKER_PROXY_ENABLED:-false}" == "true" ]]; then
    check "Docker proxy (2375)" \
      "curl -sf http://127.0.0.1:2375/version" \
      "journalctl -u circuitbreaker-docker-proxy -n 30"
  fi
  # Check nginx on 443 (TLS) or CB_PORT (no-TLS)
  ext_port=443
  nginx_scheme="https"
  nginx_curl_opts="-sfk"
  if nc -z 127.0.0.1 443 2>/dev/null; then
    check "nginx (443)"        "nc -z 127.0.0.1 443"             "nginx -t && journalctl -u nginx -n 30"
  else
    ext_port="${CB_PORT:-8088}"
    nginx_scheme="http"
    nginx_curl_opts="-sf"
    check "nginx (${ext_port})"  "nc -z 127.0.0.1 ${ext_port}"  "nginx -t && journalctl -u nginx -n 30"
  fi

  # A bare TCP connect (above) only proves nginx is listening — it says
  # nothing about whether nginx can actually *proxy* a request to the
  # backend. SELinux's httpd_can_network_connect boolean is off by default on
  # Fedora/RHEL and blocks exactly that: nginx's connect() to 127.0.0.1:8000
  # gets "Permission denied", so every API call 502s while the Backend API
  # check above (which curls the backend directly, bypassing nginx) stays
  # green — this is the only check that actually routes through nginx.
  check "nginx → backend proxy" \
    "curl ${nginx_curl_opts} ${nginx_scheme}://127.0.0.1:${ext_port}/api/v1/health" \
    "getsebool httpd_can_network_connect; setsebool -P httpd_can_network_connect on; tail -20 /var/log/nginx/error.log"

  # A local-only check above can be green while the host firewall or SELinux
  # silently drops every external connection — neither shows up in
  # `journalctl -u nginx`, so this looks like a working install until someone
  # tries to reach it from off-box.
  if command -v firewall-cmd &>/dev/null && systemctl is-active --quiet firewalld; then
    check "firewalld allows :${ext_port}" \
      "( firewall-cmd --list-ports; firewall-cmd --list-services ) 2>/dev/null | grep -qE '(^|[ ,])(${ext_port}/tcp|https|http)([ ,]|\$)'" \
      "firewall-cmd --permanent --add-port=${ext_port}/tcp && firewall-cmd --reload"
  fi
  if command -v getenforce &>/dev/null && [[ "$(getenforce)" != "Disabled" ]] && command -v semanage &>/dev/null; then
    check "SELinux allows nginx:${ext_port}" \
      "semanage port -l 2>/dev/null | grep -qE \"^[a-zA-Z0-9_]+[[:space:]]+tcp[[:space:]].*\\<${ext_port}\\>\"" \
      "semanage port -a -t http_port_t -p tcp ${ext_port} || semanage port -m -t http_port_t -p tcp ${ext_port}"
  fi
  echo ""
  [[ $FAILED -eq 0 ]] && echo "  All systems operational." \
                       || echo "  $FAILED check(s) failed. Fix top-down — each service depends on the one above."
  echo ""
}

cmd_logs() {
  journalctl -f \
    -u circuitbreaker-postgres \
    -u circuitbreaker-pgbouncer \
    -u circuitbreaker-redis \
    -u circuitbreaker-nats \
    -u circuitbreaker-backend \
    -u "circuitbreaker-worker@*" \
    -u nginx
}

cmd_restart() {
  echo "Restarting Circuit Breaker..."
  systemctl restart circuitbreaker.target
  sleep 3
  cmd_status
}

cmd_update() {
  echo "Updating Circuit Breaker..."
  bash <(curl -fsSL https://raw.githubusercontent.com/BlkLeg/CircuitBreaker/main/install.sh) --upgrade
}

cmd_backup() {
  TS=$(date +%Y%m%d-%H%M%S)
  FILE="${CB_DATA_DIR}/backups/cb-backup-${TS}.sql"
  echo "Backing up to $FILE..."
  PGPASSWORD="$CB_DB_PASSWORD" pg_dump \
    -h 127.0.0.1 -p 6432 -U breaker circuitbreaker > "$FILE"
  echo "Done: $FILE"
}

cmd_version() {
  cat /opt/circuitbreaker/share/VERSION 2>/dev/null || echo "unknown"
}

cmd_uninstall() {
  read -rp "  Remove Circuit Breaker and ALL data? [y/N]: " confirm
  [[ "$confirm" != "y" ]] && echo "Cancelled." && exit 0

  echo "Stopping Docker proxy container..."
  docker stop cb-docker-proxy 2>/dev/null || true
  docker rm cb-docker-proxy 2>/dev/null || true

  echo "Stopping and disabling all services..."
  systemctl stop \
    circuitbreaker-postgres circuitbreaker-pgbouncer \
    circuitbreaker-redis circuitbreaker-nats circuitbreaker-backend \
    "circuitbreaker-worker@discovery" "circuitbreaker-worker@notification" \
    "circuitbreaker-worker@telemetry" "circuitbreaker-worker@monitor_scheduler" \
    "circuitbreaker-worker@monitor_poll" \
    nginx 2>/dev/null || true

  systemctl disable \
    circuitbreaker-postgres circuitbreaker-pgbouncer \
    circuitbreaker-redis circuitbreaker-nats circuitbreaker-backend \
    "circuitbreaker-worker@discovery" "circuitbreaker-worker@notification" \
    "circuitbreaker-worker@telemetry" "circuitbreaker-worker@monitor_scheduler" \
    "circuitbreaker-worker@monitor_poll" \
    circuitbreaker-docker-proxy \
    circuitbreaker.target nginx 2>/dev/null || true

  echo "Killing any remaining CircuitBreaker processes..."
  pkill -u breaker 2>/dev/null || true
  sleep 2
  pkill -9 -u breaker 2>/dev/null || true

  echo "Removing systemd unit files..."
  rm -f /etc/systemd/system/circuitbreaker-*.service
  rm -f /etc/systemd/system/circuitbreaker-*.timer
  rm -f /etc/systemd/system/circuitbreaker.target
  rm -f /etc/systemd/system/circuitbreaker.slice
  systemctl daemon-reload
  systemctl reset-failed 2>/dev/null || true

  echo "Removing application files..."
  rm -rf /opt/circuitbreaker /etc/circuitbreaker /etc/nats
  rm -rf "${CB_DATA_DIR}"

  echo "Removing Nginx configuration..."
  rm -f /etc/nginx/conf.d/circuitbreaker.conf

  echo "Removing NATS binary..."
  rm -f /usr/local/bin/nats-server

  echo "Removing CB CLI..."
  rm -f /usr/local/bin/cb

  echo "Removing system user..."
  userdel -r breaker 2>/dev/null || userdel breaker 2>/dev/null || true

  echo "Removing /etc/hosts entry..."
  if [[ -n "${CB_FQDN:-}" ]]; then
    sed -i "/[[:space:]]${CB_FQDN}$/d" /etc/hosts
  fi

  echo "Removing Nginx package..."
  apt-get remove -y nginx 2>/dev/null || dnf remove -y nginx 2>/dev/null || pacman -R --noconfirm nginx 2>/dev/null || true

  echo "Removing NodeSource repository..."
  rm -f /etc/apt/sources.list.d/nodesource.list
  rm -f /usr/share/keyrings/nodesource.gpg

  echo "Circuit Breaker fully removed."
}

case "${1:-help}" in
  status)    cmd_status    ;;
  doctor)    cmd_doctor    ;;
  logs)      cmd_logs      ;;
  restart)   cmd_restart   ;;
  update)    cmd_update    ;;
  backup)    cmd_backup    ;;
  version)   cmd_version   ;;
  uninstall) cmd_uninstall ;;
  *)
    echo ""
    echo "  cb - Circuit Breaker CLI"
    echo ""
    echo "  Commands:"
    echo "    cb status     Show all service statuses"
    echo "    cb doctor     Run health checks and diagnose issues"
    echo "    cb logs       Tail all logs (live)"
    echo "    cb restart    Restart all services"
    echo "    cb update     Update to latest version"
    echo "    cb backup     Backup database"
    echo "    cb version    Show installed version"
    echo "    cb uninstall  Remove Circuit Breaker"
    echo ""
    ;;
esac
