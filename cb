# MAIN
###############################################################################

case "${1:-help}" in
  status)          cmd_status ;;
  start)           cmd_start ;;
  stop)            cmd_stop ;;
  restart)         cmd_restart ;;
  logs)            cmd_logs "${2:-}" ;;
  upgrade)         cmd_upgrade "${2:-}" ;;
  update)          cmd_update "${2:-}" ;;
  backup)          cmd_backup ;;
  restore)         cmd_restore "${2:-}" ;;
  config)          cmd_config "${2:-}" "${3:-}" ;;
  migrate)         cmd_migrate ;;
  shell)           cmd_shell ;;
  vault-recover)   cmd_vault_recover ;;
  version)         cmd_version ;;
  uninstall)       cmd_uninstall ;;
  help|--help|-h)  usage ;;
  *) echo -e "\n  Unknown command: ${RED}$1${R}\n"; usage; exit 1 ;;
esac
