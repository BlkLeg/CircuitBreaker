# Root .env — read by Docker Compose for build-arg interpolation.
# This file is gitignored. Copy from .env.example and fill in secrets.

# Sentry frontend DSN (baked into the JS bundle at build time via VITE_SENTRY_DSN build arg)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production

# Persistent Fernet key for the telemetry credential vault (SMTP passwords, etc.).
# Without this, an ephemeral key is generated on each restart and saved credentials break.
# Generate a new one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CB_VAULT_KEY=

# Custom Postgres connection variables (optional)
# CB_DB_PASSWORD=breaker
# CB_DB_URL=postgresql://breaker:${CB_DB_PASSWORD:-breaker}@postgres:5432/circuitbreaker

# Postgres connection pool (backend). Defaults: DB_POOL_SIZE=10, DB_MAX_OVERFLOW=10.
# On Raspberry Pi or low-memory hosts, use smaller values to reduce memory (e.g. DB_POOL_SIZE=3, DB_MAX_OVERFLOW=2).
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=10
