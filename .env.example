# Root .env — read by Docker Compose for build-arg interpolation.
# This file is gitignored. Copy from .env.example and fill in secrets.

# ── Required Secrets ──────────────────────────────────────────────────────────
# Fernet key for the credential vault (encrypts integration tokens, SMTP passwords, etc.).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CB_VAULT_KEY=

# Postgres password for the embedded breaker user. Pick something strong.
# CB_DB_PASSWORD=

# Postgres connection string. Leave unset for embedded Postgres.
# CB_DB_URL=postgresql://breaker:${CB_DB_PASSWORD:-breaker}@postgres:5432/circuitbreaker

# ── Connection Pool ───────────────────────────────────────────────────────────
# Defaults: 10 / 10. Lower on Raspberry Pi or low-memory hosts (e.g. 3 / 2).
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=10

# ── Security ──────────────────────────────────────────────────────────────────
# Internal NATS bus auth token. Required for mono-image deployments.
# Generate: openssl rand -base64 32
# NATS_AUTH_TOKEN=

# Air-gap mode: disables all network scanning when true.
# CB_AIRGAP=false

# TCP Docker API proxy URL. Preferred over mounting the Docker socket.
# CB_DOCKER_HOST=tcp://docker-socket-proxy:2375

