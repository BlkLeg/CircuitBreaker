# Circuit Breaker — NATS JetStream configuration
# Generated by envsubst during install
# Variables: NATS_AUTH_TOKEN, CB_DATA_DIR

listen: 127.0.0.1:4222

authorization {
    token: "${NATS_AUTH_TOKEN}"
}

jetstream {
    store_dir: "${CB_DATA_DIR}/nats"
    max_mem: 64MB
    max_file: 1GB
}

