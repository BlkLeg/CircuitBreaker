# Circuit Breaker — environment template
# Copy to .env and edit as needed before first deployment.

# ── Image / Tag ───────────────────────────────────────────────────────────────
# Image tag for prebuilt compose. Use "latest" or a specific version like "v0.2.2".
CB_TAG=latest

# ── Required Secrets (all three MUST be set before first run) ─────────────────
# Postgres password for the embedded breaker user. Pick something strong.
CB_DB_PASSWORD=

# Fernet key for the credential vault (encrypts integration tokens, SMTP passwords, etc.).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CB_VAULT_KEY=

# Internal NATS message bus auth token. Required — the container refuses to start without it.
# Generate: openssl rand -base64 32
NATS_AUTH_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use the embedded Postgres. Set to an external host to use your own.
# CB_DB_URL=postgresql://breaker:${CB_DB_PASSWORD}@postgres:5432/circuitbreaker

# Connection pool tuning. Lower on Raspberry Pi / low-memory hosts (e.g. 3 / 2).
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=10

# ── TLS / Domain ─────────────────────────────────────────────────────────────
# Hostname used in self-signed cert CN and HSTS. Defaults to "circuitbreaker.local".
CB_DOMAIN=circuitbreaker.local

# Email for Let's Encrypt ACME (only needed when using certbot with a public domain).
CB_TLS_EMAIL=

# Docker volume name for locally-generated TLS certs.
CB_LOCAL_CERTS=local_certs

# ── Networking / Ports ────────────────────────────────────────────────────────
# Host ports mapped to the container's HTTP and HTTPS listeners.
CB_PORT_HTTP=80
CB_PORT_HTTPS=443

# Host path for persistent data (Postgres, Redis, uploads, TLS certs, etc.).
# CB_DATA_DIR=./circuitbreaker-data

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave unset to use the embedded Redis (auto-authenticated with a generated password).
# Set only when pointing to an external Redis instance.
# CB_REDIS_URL=redis://:yourpassword@redis-host:6379/0

# ── Security Hardening ────────────────────────────────────────────────────────
# Air-gap mode: when true, all network scanning is disabled (HTTP 403).
# Useful for offline / isolated deployments that only use manual inventory.
CB_AIRGAP=false

# Static bearer token for headless API access and metrics scraping.
# Compared with constant-time hmac.compare_digest. Leave blank to disable.
CB_API_TOKEN=

# Require WSS (TLS) for WebSocket connections. Set true if all clients connect over HTTPS.
CB_WS_REQUIRE_WSS=

# ── Docker Discovery ─────────────────────────────────────────────────────────
# The Docker socket is NOT mounted by default for security reasons.
# To enable Docker container discovery, choose one of:
#   1. Compose override: docker compose -f docker-compose.yml -f docker-compose.socket.yml up -d
#   2. TCP proxy (recommended): set CB_DOCKER_HOST to a Docker API proxy
#      e.g. CB_DOCKER_HOST=tcp://docker-socket-proxy:2375
CB_DOCKER_HOST=

# ── Optional: NATS Advanced ──────────────────────────────────────────────────
# Only needed if connecting to an external NATS cluster instead of the embedded one.
# NATS_USER=
# NATS_PASSWORD=
# NATS_TLS=

# ── Optional: Monitoring ─────────────────────────────────────────────────────
# Set to false to skip TLS cert verification for uptime monitor HTTP probes.
# Only use for homelab hosts with self-signed certs. Default: true.
# CB_MONITOR_VERIFY_TLS=true

