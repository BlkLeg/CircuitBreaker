# Circuit Breaker — environment template
# Copy to .env and edit as needed.
#
# For prebuilt compose (docker-compose.prod.yml):
#   CB_TAG=latest           Image tag suffix (backend-latest, frontend-latest)
#   CB_VAULT_KEY=           Fernet key for credential vault (auto-generated at OOBE if empty)
#   CB_DOMAIN=circuitbreaker.local
#   CB_TLS_EMAIL=           Required for ACME/Let's Encrypt on public domains
#   CB_LOCAL_CERTS=local_certs
#
# Optional PostgreSQL (required for prod stack; set a strong password):
#   CB_DB_PASSWORD=         No default. Set a strong password for the breaker user.
#   CB_DB_URL=postgresql://breaker:${CB_DB_PASSWORD}@postgres:5432/circuitbreaker
#
# Security hardening (see docs/deployment-security.md):
#   NATS_AUTH_TOKEN=        Optional. When set, NATS server and backend/workers use token auth.
#   NATS_USER=               Optional. NATS user (if using user/password auth; server must be configured).
#   NATS_PASSWORD=           Optional. NATS password.
#   NATS_TLS=                Optional. Set to true to connect to NATS over TLS (server must have TLS).
#   CB_WS_REQUIRE_WSS=      Optional. Set to true to reject WebSocket connections that are not over WSS.
#   CB_API_TOKEN=            Optional. Static bearer token for API write operations and metrics scraping.

CB_TAG=latest
CB_VAULT_KEY=
CB_DOMAIN=circuitbreaker.local
CB_TLS_EMAIL=
CB_LOCAL_CERTS=local_certs

# PostgreSQL (required for prod compose)
CB_DB_PASSWORD=
CB_DB_URL=postgresql://breaker:${CB_DB_PASSWORD}@postgres:5432/circuitbreaker

# Optional: NATS auth and TLS
NATS_AUTH_TOKEN=
NATS_USER=
NATS_PASSWORD=
NATS_TLS=

# Optional: backend security
CB_WS_REQUIRE_WSS=
CB_API_TOKEN=

# Build-time (source compose only)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
