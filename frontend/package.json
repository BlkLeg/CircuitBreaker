  "scripts": {
    "syncversion": "node -e \"const fs=require('fs');const v=fs.readFileSync('../VERSION','utf8').trim();const p=JSON.parse(fs.readFileSync('./package.json','utf8'));p.version=v;fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n');console.log('version synced to '+v);\"",
    "start": "vite",
    "build": "npm run syncversion && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
