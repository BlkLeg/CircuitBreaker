# Copy this to .env and fill in values for your environment.
# frontend/.env is gitignored for .env.local variants; this file is safe to commit.

VITE_TOKEN_STORAGE_KEY=circuit-breaker-auth-token
API_TARGET=http://localhost:8000

# Sentry frontend error monitoring. Leave blank to disable Sentry in this environment.
# The DSN is baked into the JS bundle at build time by Vite.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
