# localStorage key used to persist the auth token.
# Change this if you need to isolate multiple instances running on the same origin.
VITE_TOKEN_STORAGE_KEY=circuit-breaker-auth-token

# Backend URL used by the Vite dev-server proxy.
# Only applies during local development (npm run dev).
API_TARGET=http://localhost:8000

# Sentry frontend error monitoring (baked into the JS bundle at build time by Vite).
# Leave blank to disable Sentry.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
