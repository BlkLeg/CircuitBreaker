{
  "name": "circuit-breaker-ui",
  "version": "0.2.2",
  "private": true,
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@tanstack/react-virtual": "^3.13.21",
    "@uiw/react-md-editor": "^4.0.11",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "dompurify": "^3.3.2",
    "framer-motion": "^12.34.4",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.574.0",
    "mitt": "^3.0.1",
    "plotly.js-dist-min": "^2.35.2",
    "prop-types": "^15.8.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.7.3",
    "react-markdown": "^9.0.1",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.24.0",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.15.0",
    "sigma": "^3.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "scripts": {
    "syncversion": "node -e \"const fs=require('fs');const v=fs.readFileSync('../../VERSION','utf8').trim();const p=JSON.parse(fs.readFileSync('./package.json','utf8'));p.version=v;fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n');console.log('version synced to '+v);\"",
    "start": "vite",
    "build": "npm run syncversion && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n:extract": "i18next-scanner --config i18next-scanner.config.js",
    "i18n:sync": "i18next-json-sync public/locales/ src/ --config i18next.json",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bundle-analyze": "ANALYZE=true npm run build",
    "prepare": "cd ../.. && (husky 2>/dev/null || true)"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "npx prettier --write"
    ],
    "../backend/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "elkjs": "^0.11.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "i18next-json-sync": "^3.1.2",
    "i18next-scanner": "^4.6.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "madge": "^8.0.0",
    "msw": "^2.12.10",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.11",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
