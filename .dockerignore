# Version control
.git

# Python virtual environments
.venv
.venv-mkdocs/

# Node modules (will be installed fresh inside the builder stage)
node_modules
apps/frontend/node_modules
docker/node_modules

# Python bytecode
**/__pycache__
**/*.pyc
**/*.pyo

# Secrets and local env overrides
apps/backend/.env
apps/backend/.env.*
docker/.env

# Build artefacts (rebuilt inside Docker)
dist/
apps/frontend/dist/
build/
*.spec

# Editor / IDE and tool caches
.claude/
.cursor/
.vscode/
.cache/
*.swp
*.swo

# Internal planning docs
.INTERNAL/

# Docs (not needed in the image)
docs/

# MkDocs HTML output (tracked in git for GitHub Pages, not needed in image)
site/
mkdocs.yml

# Screenshots and icon source library (not needed at runtime)
screenshots/
cb-icon_lib/

# Root-level runtime data (SQLite db etc.)
data/

# Host install/uninstall scripts (not needed inside container)
install.sh
uninstall.sh

# Markdown files (README and DocsPage needed for native build)
*.md
!README.md
!DocsPage.md

# Tests (not needed in the production image)
apps/backend/tests/
tests/

# Security reports
SECURITY_REPORTS/

# CI / GitHub Actions
.github/

# OS noise
.DS_Store
Thumbs.db
