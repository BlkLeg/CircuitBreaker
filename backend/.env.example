# Copy this file to .env and edit as needed
DATABASE_URL=sqlite:///./data/app.db
DEBUG=false
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Base directory for all user uploads (profile photos, docs, branding, icons).
# In Docker single-image deployments this is set to /data/uploads via ENV in the Dockerfile.
# In Docker Compose it is set to /app/data/uploads via the environment block.
UPLOADS_DIR=data/uploads
